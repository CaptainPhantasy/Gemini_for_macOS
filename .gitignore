node_modules/
build/
dist/
coverage/
.DS_Store
*.log

# ─── Secrets & environment ───────────────────────────────
# All .env variants are ignored. .env.example is the only tracked template.
# Users copy .env.example → .env and fill in real values.
.env
.env.*
!.env.example

# Backup files may contain API keys from settings exports
gemini-backup-*.json
*-backup-*.json

# OAuth PKCE verifier / token cache (on-disk if offline flow is used)
.oauth-state.json
oauth-tokens.json

# Scheduler lock files (contain action IDs, not secrets, but are ephemeral)
/tmp/gemini-for-macos-schedule-*.lock

# ─── Local-only artifacts ────────────────────────────────
docs/quarantine/
docs/screenshots/
.local-backup/
test-results.json
test-report.txt
test-results/

# ─── Ephemeral tool state & orchestration ────────────────
.pi/
.pi-lens/
.sprint/
.bg-shell/

# ─── Agent memory directory ──────────────────────────────
# Track README, ignore runtime session files (summaries, task queues, night reports)
.gemini-memory/*
!.gemini-memory/README.md

# ─── Provider API keys (future: stored per-provider in .env) ──
# Together.ai, OpenRouter, HuggingFace, Ollama cloud keys all go in .env
# which is already covered by the .env pattern above.

# ─── IDE / editor artifacts ──────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
